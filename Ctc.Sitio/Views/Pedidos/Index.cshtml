@model IEnumerable<Dominio.Pedido>

@{
    ViewData["Title"] = "Listado de Pedidos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Listado de Pedidos</h1>
    <a asp-action="Crear" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Nuevo Pedido
    </a>
</div>

<table class="table table-striped table-hover border shadow-sm">

    <thead class="table-dark">
        <tr>
            <th>ID Pedido</th>
            <th>ID Cliente</th>
            <th>Fecha</th>
            <th>Monto Total</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.IdCliente</td>
                    <td>@item.Fecha.ToShortDateString()</td>
                    <td>$ @item.Total</td>
                    <td>
                        <span class="badge @(item.Estado == "Entregado" ? "bg-success" : "bg-warning text-dark")">
                            @item.Estado
                        </span>
                    </td>
                    <td>
                        <a asp-action="Detalles" asp-route-id="@item.Id" class="btn btn-info btn-sm">Ver</a>
                        <form asp-action="Eliminar" method="post" style="display:inline;">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-danger btn-sm"
                                    onclick="return confirm('¿Estás seguro de que deseas eliminar este pedido?')">
                                Eliminar
                            </button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center text-muted">No hay pedidos cargados aún.</td>
            </tr>
        }
    </tbody>
</table>