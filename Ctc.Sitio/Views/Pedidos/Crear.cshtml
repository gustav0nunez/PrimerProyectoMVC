@model Dominio.Pedido

<h1>Nuevo Pedido</h1>

<form asp-action="Crear" method="post">

    <div class="row mb-4">
        <div class="col-md-4">
            <label class="form-label">Fecha:</label>
            <input asp-for="Fecha" type="date" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Cliente:</label>
            <select asp-for="IdCliente" class="form-select" asp-items="@(new SelectList(ViewBag.Clientes, "Id", "Nombre"))">
                <option value="">-- Seleccione un cliente --</option>
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label">Total:</label>
            <input asp-for="Total" class="form-control" type="number" step="0.01" />
        </div>
    </div>

    <div class="mb-3">
        <button type="submit" asp-action="AgregarItem" formnovalidate class="btn btn-success">
            + Agregar Fila de Producto
        </button>
    </div>

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>ID Producto</th>
                <th>Cantidad</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.DetallesPedido != null)
            {
                @for (int i = 0; i < Model.DetallesPedido.Count; i++)
                {
                    <tr>
                        <td>
                            <input asp-for="DetallesPedido[i].ProductoId" class="form-control" type="number" placeholder="Ej: 1">
                        </td>
                        <td>
                            <input asp-for="DetallesPedido[i].Cantidad" class="form-control" type="number" value="1">
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <div class="mt-4">
        <button type="submit" class="btn btn-primary">Guardar Pedido Completo</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Volver al Listado</a>
    </div>

</form>