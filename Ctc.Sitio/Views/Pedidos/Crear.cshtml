@model Pedido

<h1>Nuevo Pedido</h1>

@if (ViewBag.MensajeError != null)
{
    <div class="alert alert-danger">
        @ViewBag.MensajeError
    </div>
}
<form asp-action="Crear" method="post">


    <table class="table table-bordered table-striped">
        <tr>
            <th>Producto</th>
            <th>Cantidad</th>
            <th></th>
        </tr>
        for (int i = 0; i < Model.DetallesPedido.Count; i++)
        {
            <tr>
                <td>
                    <input asp-for="DetallesPedido[@i].ProductoId">

                </td>
            </tr>
        }
    </table>


















    <div>
        <label>Fecha:</label>
        <input asp-for="Fecha" type="date" class="form-control" />
        <span asp-validation-for="Fecha" class="text-danger"></span>
    </div>

    <div>
        <label>Monto:</label>
        <input asp-for="" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div>
        <label>Cliente:</label>
        <input asp-for="" class="form-control" />
        <span asp-validation-for="Direccion" class="text-danger"></span>
    </div>

    <div>
        <label>Producto Cantidad:</label>
        <input asp-for="" type="date" class="form-control" />
        <span asp-validation-for="" class="text-danger"></span>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Crear Cliente</button>

        <a asp-action="Index" class="btn btn-secondary ms-2">Volver al Listado</a>
    </div>
</form>

