@model Dominio.Pedido

<div class="container mt-4">
    <h2>Crear Nuevo Pedido</h2>
    <hr />

    <form asp-action="Crear" method="post">

        <div asp-validation-summary="All" class="alert alert-danger fw-bold"></div>
        <div class="row mb-4">
            <div class="col-md-4">
                <label class="form-label">Fecha:</label>
                <input asp-for="Fecha" type="date" class="form-control" />
                <span asp-validation-for="Fecha" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label class="form-label">Cliente:</label>
                <select asp-for="IdCliente" class="form-select" asp-items="@(new SelectList(ViewBag.Clientes, "Id", "Nombre"))">
                    <option value="">-- Seleccione un cliente --</option>
                </select>
                <span asp-validation-for="IdCliente" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label class="form-label">Total ($):</label>
                <input asp-for="Total" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="Total" class="text-danger"></span>
            </div>
        </div>

        <hr />

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4>Detalles del Pedido</h4>

            <button type="submit" asp-action="AgregarItem" formnovalidate class="btn btn-success">
                + Agregar Fila de Producto
            </button>
        </div>

        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>ID Producto</th>
                    <th>Cantidad</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.DetallesPedido != null)
                {
                    
                    @for (int i = 0; i < Model.DetallesPedido.Count; i++)
                    {
                        <tr>
                            <td>
                                <select asp-for="DetallesPedido[i].ProductoId"
                                        class="form-control"
                                        asp-items="@(new SelectList(ViewBag.Productos, "Id_producto", "Nombre"))">
                                    <option value="">Seleccione un producto</option>
                                </select>
                            </td>
                            <td>
                                <input asp-for="DetallesPedido[i].Cantidad" class="form-control" type="number" />
                            </td>
                            <td class="text-center">
                                <button type="submit" asp-action="QuitarItem" asp-route-indice="@i" formnovalidate class="btn btn-danger btn-sm">
                                    Quitar Fila
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        <div class="mt-5 text-end">
            <a asp-action="Index" class="btn btn-secondary me-2">Cancelar y Volver</a>

            <button type="submit" class="btn btn-primary btn-lg">
                <i class="bi bi-save"></i> Confirmar Pedido Completo
            </button>
        </div>

    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}